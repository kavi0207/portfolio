flowchart LR
    NVD["NVD<br/>CVEs · CVSS · CWE"]
    EPSS["EPSS<br/>exploit probability"]
    KEV["CISA KEV / VulnCheck<br/>confirmed exploited"]
    EXP["ExploitDB · Nuclei<br/>Metasploit"]
    ATTACK["MITRE ATT&CK<br/>actors · malware · TTPs"]
    TF["ThreatFox<br/>live malware IOCs"]

    ING["1 · INGEST<br/>Dagster assets<br/>per-feed sync"]
    ENR["2 · ENRICH & MAP<br/>CVE → CWE → ATT&CK<br/>CAPEC · D3FEND"]
    LLM["3 · LLM ENRICHMENT<br/>Claude / Vertex<br/>infer CWEs · map techniques"]
    SCORE["4 · RISK SCORING<br/>0–100 + level"]
    DB[("PostgreSQL<br/>world schema")]
    OUT["SOC & Vuln-Mgmt<br/>'patch these first'"]

    NVD --> ING
    EPSS --> ING
    KEV --> ING
    EXP --> ING
    ATTACK --> ING
    TF --> ING
    ING --> ENR --> LLM --> SCORE
    ING --> SCORE
    SCORE --> DB --> OUT

    classDef src fill:#eff6ff,stroke:#3b82f6,color:#0f172a
