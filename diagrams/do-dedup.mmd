flowchart LR
    RAW["Raw DarkOwl rows<br/>(many per finding,<br/>multiple query types)"]

    MATCH["domain_matching.py<br/>normalize host / domain<br/>extract &lt;em&gt; terms<br/>exact OR subdomain match"]
    IDENT["finding_identity.py<br/>finding_id = UUID5(result_id | domain)<br/>query precedence:<br/>email &gt; domain &gt; website &gt; keyword<br/>choose canonical row"]
    BODY["body_extract.py<br/>500-char window around<br/>matched-domain mention<br/>→ evidence snippet"]

    OUT["1 canonical, deduped,<br/>evidence-backed finding"]

    RAW --> MATCH --> IDENT --> BODY --> OUT

